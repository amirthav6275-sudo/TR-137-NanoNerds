  const ip=prompt('Enter reviewer IP (or leave blank for random):','198.51.100.'+Math.floor(Math.random()*255));
  const id=reviews.length+1;
  reviews.push({id,text:text.trim(),author:`user_new${id}`,date:new Date().toISOString().split('T')[0],rating:5,ip:ip||randomIP(),blocked:false});
  addTimelineEvent(`New review added: #${id}`,ip,'info');
  toast('Review added to network','success');
  updateStats();renderAll();selectReview(id);
}

// ===================== NAV PANEL SWITCHING =====================
function showPanel(name){
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.toggle('active',t.dataset.panel===name));
  document.querySelectorAll('.panel').forEach(p=>p.classList.toggle('active',p.id==='panel-'+name));
  if(name==='reviews')renderReviews();
  if(name==='ipblock')renderIPGrid();
  if(name==='analytics')renderAnalytics();
}

document.querySelectorAll('.nav-tab').forEach(btn=>{
  btn.addEventListener('click',()=>showPanel(btn.dataset.panel));
});

// ===================== RENDER ALL =====================
function renderAll(){
  renderTree();
  renderRightPanel();
  // Re-render active panel
  const active=document.querySelector('.panel.active');
  if(active){
    const id=active.id.replace('panel-','');
    if(id==='reviews')renderReviews();
    if(id==='ipblock')renderIPGrid();
    if(id==='analytics')renderAnalytics();
  }
}

