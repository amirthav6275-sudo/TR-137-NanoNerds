// ===================== TIMELINE =====================
function addTimelineEvent(msg,ip,type='info'){
  const colors={info:'var(--cyan)',warning:'var(--orange)',danger:'var(--red)',success:'var(--green)'};
  const item={msg,ip,type,time:timeNow()};
  timelineFeed.unshift(item);
  if(timelineFeed.length>50)timelineFeed.pop();
  const feed=document.getElementById('timeline-feed');
  if(feed){
    const el=document.createElement('div');
    el.className='tl-item fade-in';
    el.innerHTML=`<div class="tl-dot" style="background:${colors[type]||colors.info}"></div>
      <div class="tl-time">${item.time}</div>
      <div><div class="tl-msg">${msg}</div>${ip?`<div class="tl-ip">${ip}</div>`:''}</div>`;
    feed.insertBefore(el,feed.firstChild);
    if(feed.children.length>30)feed.lastChild.remove();
  }
}
function clearTimeline(){document.getElementById('timeline-feed').innerHTML='';timelineFeed=[];}

