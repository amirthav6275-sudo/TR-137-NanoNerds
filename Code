// ===================== REVIEWS PANEL =====================
function filterReviews(f){
  currentFilter=f;
  ['all','fake','clean','blocked'].forEach(x=>{
    const btn=document.getElementById('f-'+x);
    if(btn){btn.style.borderColor=x===f?'var(--cyan)':'';btn.style.color=x===f?'var(--cyan)':'';}
  });
  renderReviews();
}

function renderReviews(){
  const list=document.getElementById('reviews-list');
  let filtered=reviews;
  if(currentFilter==='fake')filtered=reviews.filter(r=>fakeScore(r,reviews)>60);
  else if(currentFilter==='clean')filtered=reviews.filter(r=>fakeScore(r,reviews)<=35);
  else if(currentFilter==='blocked')filtered=reviews.filter(r=>r.blocked);

  list.innerHTML=filtered.map(r=>{
    const sc=fakeScore(r,reviews);
    const color=scoreColor(sc);
    const cls=scoreClass(sc);
    const geo=IP_GEO[r.ip]||{country:'Unknown',risk:0,type:'Unknown'};
    return `<div class="rev-card ${cls}${r.blocked?' blocked':''}" data-id="${r.id}" onclick="selectReview(${r.id})" style="${r.blocked?'border-color:rgba(255,45,85,.3)':''}">
      <div class="rev-top">
        <span class="rev-id">#${r.id}</span>
        <span class="rev-status-badge" style="color:${color};background:${color}18;border:1px solid ${color}40">${r.blocked?'BLOCKED':scoreLabel(sc)}</span>
        <span class="rev-author">${r.author}</span>
        <span class="rev-ip">${r.ip}</span>
        <span style="font-size:9px;color:var(--muted)">📍${geo.country}</span>
        <div class="rev-score-wrap" style="margin-left:auto">
          <div class="rev-score-bar"><div class="rev-score-fill" style="width:${sc}%;background:${color}"></div></div>
          <span class="rev-score-num" style="color:${color}">${sc}</span>
        </div>
      </div>
      <div class="rev-text">${r.text}</div>
      <div style="display:flex;gap:6px;margin-top:8px;">
        ${r.blocked
