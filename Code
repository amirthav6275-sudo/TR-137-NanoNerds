// ===================== BLOCK IP =====================
function blockIP(ip,reason,silent=false){
  if(blockedIPs.has(ip)){toast(`IP ${ip} already blocked`,'info');return;}
  blockedIPs.add(ip);
  reviews.forEach(r=>{if(r.ip===ip)r.blocked=true;});
  const entry={ip,reason,time:timeNow()};
  blockLog.unshift(entry);
  if(!silent){
    toast(`🚫 Blocked IP: ${ip}`,'error',4000);
    addTimelineEvent(`IP blocked: ${reason||'Manual block'}`,ip,'danger');
  }
  updateStats();
  renderAll();
}

function unblockIP(ip){
  blockedIPs.delete(ip);
  reviews.forEach(r=>{if(r.ip===ip)r.blocked=false;});
  blockLog=blockLog.filter(e=>e.ip!==ip);
  toast(`✓ Unblocked IP: ${ip}`,'success');
  addTimelineEvent(`IP unblocked`,ip,'success');
  updateStats();
  renderAll();
}

function manualBlockIP(){
  const ip=document.getElementById('manual-ip-input').value.trim();
  if(!ip){toast('Enter a valid IP address','error');return;}
  showModal('🚫 BLOCK IP ADDRESS',`Block <b style="color:var(--cyan)">${ip}</b> from submitting reviews?<br><br>All existing reviews from this IP will be flagged as blocked.`,()=>{
    blockIP(ip,'Manual block');
    document.getElementById('manual-ip-input').value='';
  });
}

function blockAllFake(){
  const fakes=reviews.filter(r=>fakeScore(r,reviews)>60&&!r.blocked);
  if(!fakes.length){toast('No new fake reviews to block','info');return;}
  showModal('🚨 BLOCK ALL FAKE REVIEWS',`Auto-block <b style="color:var(--red)">${fakes.length} fake reviews</b> and their associated IPs?<br><br>This will block reviews from <b>${new Set(fakes.map(r=>r.ip)).size}</b> unique IP addresses.`,()=>{
    const ips=new Set(fakes.map(r=>r.ip));
    ips.forEach(ip=>blockIP(ip,'Auto-blocked: High fake score',true));
    fakes.forEach(r=>r.blocked=true);
    toast(`🚫 Blocked ${fakes.length} fake reviews from ${ips.size} IPs`,'error',5000);
    addTimelineEvent(`Mass block: ${fakes.length} fake reviews blocked`,`${ips.size} IPs`,'danger');
    updateStats();renderAll();
  });
}

function blockAllSuspiciousIPs(){
  const suspicious=Object.entries(IP_GEO).filter(([ip,[,v]])=>v&&v.risk>70).map(([ip])=>ip);
  const toBlock=suspicious.filter(ip=>!blockedIPs.has(ip));
  if(!toBlock.length){toast('No new suspicious IPs found','info');return;}
  showModal('🚨 BLOCK SUSPICIOUS IPs',`Block <b style="color:var(--orange)">${toBlock.length} high-risk IPs</b>?<br><br>These IPs have risk scores above 70 (VPN, datacenter, or known bot networks).`,()=>{
    toBlock.forEach(ip=>blockIP(ip,'Auto-blocked: High IP risk score',true));
    toast(`🚫 Blocked ${toBlock.length} suspicious IPs`,'error',4000);
  });
}

// ===================== PHYLO TREE =====================
function buildClusters(){
  const n=reviews.length;
  const parent=reviews.map((_,i)=>i);
  function find(x){return parent[x]===x?x:(parent[x]=find(parent[x]));}
  for(let i=0;i<n;i++) for(let j=i+1;j<n;j++)
    if(similarity(reviews[i].text,reviews[j].text)>0.48){const ci=find(i),cj=find(j);if(ci!==cj)parent[ci]=cj;}
  const map={};
  reviews.forEach((r,i)=>{const root=find(i);if(!map[root])map[root]=[];map[root].push(i);});
  return Object.values(map);
}

function renderTree(){
  const svg=document.getElementById('tree-svg');
  const W=800,H=400;
  svg.innerHTML='';
  const clusters=buildClusters();
  const fakeClusters=clusters.filter(c=>c.length>1&&c.some(i=>fakeScore(reviews[i],reviews)>60));

  document.getElementById('node-count').textContent=reviews.length;
  document.getElementById('cluster-count').textContent=fakeClusters.length;

  if(fakeClusters.length>0){
    const ab=document.getElementById('alert-banner');
    ab.style.display='flex';
    document.getElementById('alert-text').textContent=`⚠ ${fakeClusters.length} COORDINATED FAKE CAMPAIGN${fakeClusters.length>1?'S':''} DETECTED`;
    document.getElementById('alert-sub').textContent=`${fakeClusters.reduce((a,c)=>a+c.length,0)} reviews linked across ${new Set(fakeClusters.flat().map(i=>reviews[i].ip)).size} IP addresses`;
  }

  svg.innerHTML=`<defs>
    <filter id="glow"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
    <filter id="softglow"><feGaussianBlur stdDeviation="5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
    <radialGradient id="gFake"><stop offset="0%" stop-color="#ff2d55" stop-opacity=".95"/><stop offset="100%" stop-color="#6b0020"/></radialGradient>
    <radialGradient id="gSafe"><stop offset="0%" stop-color="#00ff9d" stop-opacity=".9"/><stop offset="100%" stop-color="#003d22"/></radialGradient>
    <radialGradient id="gWarn"><stop offset="0%" stop-color="#ff9500" stop-opacity=".9"/><stop offset="100%" stop-color="#4a2c00"/></radialGradient>
    <radialGradient id="gBlocked"><stop offset="0%" stop-color="#4a6080" stop-opacity=".9"/><stop offset="100%" stop-color="#1a2030"/></radialGradient>
  </defs>`;

  const pos={};
  const R=15;
  clusters.forEach((cluster,ci)=>{
    const cx=70+(ci/Math.max(clusters.length-1,1))*(W-140);
    cluster.forEach((idx,ni)=>{
      const r=reviews[idx];
      const spread=cluster.length>1?(ni/(cluster.length-1)-.5)*180:0;
      const row=Math.floor(ni/2);
      pos[r.id]={x:cx+spread*.6,y:90+ni%2*110+row*30};
    });
  });

  // cluster halos
  clusters.forEach(cluster=>{
    if(cluster.length<2)return;
    const hasFake=cluster.some(i=>fakeScore(reviews[i],reviews)>60);
    if(!hasFake)return;
    const xs=cluster.map(i=>pos[reviews[i].id].x);
    const ys=cluster.map(i=>pos[reviews[i].id].y);
    const mx=(Math.min(...xs)+Math.max(...xs))/2;
    const my=(Math.min(...ys)+Math.max(...ys))/2;
    const rx=Math.max(Math.max(...xs)-Math.min(...xs),40)+36;
    const ry=Math.max(Math.max(...ys)-Math.min(...ys),40)+28;
    const el=document.createElementNS('http://www.w3.org/2000/svg','ellipse');
    el.setAttribute('cx',mx);el.setAttribute('cy',my);
    el.setAttribute('rx',rx);el.setAttribute('ry',ry);
    el.setAttribute('fill','rgba(255,45,85,.04)');
    el.setAttribute('stroke','rgba(255,45,85,.2)');
    el.setAttribute('stroke-width','1');
    el.setAttribute('stroke-dasharray','5 4');
    svg.appendChild(el);
  });

  // edges
  for(let i=0;i<reviews.length;i++) for(let j=i+1;j<reviews.length;j++){
    const s=similarity(reviews[i].text,reviews[j].text);
    if(s<0.52)continue;
    const p1=pos[reviews[i].id],p2=pos[reviews[j].id];
    const line=document.createElementNS('http://www.w3.org/2000/svg','line');
    line.setAttribute('x1',p1.x);line.setAttribute('y1',p1.y);
    line.setAttribute('x2',p2.x);line.setAttribute('y2',p2.y);
    line.setAttribute('stroke','#ff2d55');
    line.setAttribute('stroke-width',(s-.5)*6);
    line.setAttribute('stroke-opacity',(s-.52)/.48*.5);
    svg.appendChild(line);
  }

  // nodes
  reviews.forEach(r=>{
    const p=pos[r.id];if(!p)return;
    const sc=fakeScore(r,reviews);
    const isBlocked=r.blocked;
    const fill=isBlocked?'url(#gBlocked)':sc>60?'url(#gFake)':sc>35?'url(#gWarn)':'url(#gSafe)';
    const isSel=selectedId===r.id;
    const g=document.createElementNS('http://www.w3.org/2000/svg','g');
    g.style.cursor='pointer';
    g.addEventListener('click',()=>selectReview(r.id));

    if(isSel){
      const ring=document.createElementNS('http://www.w3.org/2000/svg','circle');
      ring.setAttribute('cx',p.x);ring.setAttribute('cy',p.y);ring.setAttribute('r',R+9);
      ring.setAttribute('fill','none');ring.setAttribute('stroke','#00f5ff');
      ring.setAttribute('stroke-width','1.5');ring.setAttribute('filter','url(#glow)');ring.setAttribute('opacity','.9');
      g.appendChild(ring);
    }
    const c=document.createElementNS('http://www.w3.org/2000/svg','circle');
    c.setAttribute('cx',p.x);c.setAttribute('cy',p.y);c.setAttribute('r',R);
    c.setAttribute('fill',fill);
    if(sc>60&&!isBlocked)c.setAttribute('filter','url(#glow)');
    if(isSel)c.setAttribute('stroke','#00f5ff'),c.setAttribute('stroke-width','2');
    g.appendChild(c);

    if(isBlocked){
      const line1=document.createElementNS('http://www.w3.org/2000/svg','line');
      line1.setAttribute('x1',p.x-8);line1.setAttribute('y1',p.y-8);
      line1.setAttribute('x2',p.x+8);line1.setAttribute('y2',p.y+8);
      line1.setAttribute('stroke','#ff2d55');line1.setAttribute('stroke-width','2');
      const line2=document.createElementNS('http://www.w3.org/2000/svg','line');
      line2.setAttribute('x1',p.x+8);line2.setAttribute('y1',p.y-8);
      line2.setAttribute('x2',p.x-8);line2.setAttribute('y2',p.y+8);
      line2.setAttribute('stroke','#ff2d55');line2.setAttribute('stroke-width','2');
      g.appendChild(line1);g.appendChild(line2);
    } else {
      const t=document.createElementNS('http://www.w3.org/2000/svg','text');
      t.setAttribute('x',p.x);t.setAttribute('y',p.y+5);
      t.setAttribute('text-anchor','middle');t.setAttribute('font-size','10');
      t.setAttribute('fill','white');t.setAttribute('font-weight','700');
      t.style.pointerEvents='none';
      t.textContent=r.id;
      g.appendChild(t);
    }
    svg.appendChild(g);
  });

  // legend
  [['#ff2d55','Fake/High Risk'],['#ff9500','Suspect'],['#00ff9d','Authentic'],['#4a6080','Blocked']].forEach(([color,label],i)=>{
    const g=document.createElementNS('http://www.w3.org/2000/svg','g');
    g.setAttribute('transform',`translate(${16+i*130},${H-26})`);
    const c=document.createElementNS('http://www.w3.org/2000/svg','circle');
    c.setAttribute('cx','7');c.setAttribute('cy','7');c.setAttribute('r','6');c.setAttribute('fill',color);c.setAttribute('opacity','.85');
    const t=document.createElementNS('http://www.w3.org/2000/svg','text');
    t.setAttribute('x','18');t.setAttribute('y','12');t.setAttribute('font-size','10');
    t.setAttribute('fill','#4a6080');t.setAttribute('font-family','Rajdhani,sans-serif');
    t.textContent=label;
    g.appendChild(c);g.appendChild(t);
    svg.appendChild(g);
  });
}

