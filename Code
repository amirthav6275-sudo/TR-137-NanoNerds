// ===================== ANALYTICS =====================
function renderAnalytics(){
  const total=reviews.length;
  const fake=reviews.filter(r=>fakeScore(r,reviews)>60).length;
  const suspect=reviews.filter(r=>{const s=fakeScore(r,reviews);return s>35&&s<=60;}).length;
  const blocked=reviews.filter(r=>r.blocked).length;
  const accuracy=total>0?Math.round((1-(fake/total))*100):100;
  const clusters=buildClusters().filter(c=>c.length>1&&c.some(i=>fakeScore(reviews[i],reviews)>60));

  document.getElementById('analytics-metrics').innerHTML=[
    {v:fake,l:'FAKE DETECTED',c:'c-red',delta:`${Math.round(fake/total*100)}% of total`},
    {v:suspect,l:'SUSPICIOUS',c:'c-orange',delta:'Need review'},
    {v:blocked,l:'BLOCKED',c:'c-red',delta:`${blockedIPs.size} IPs blocked`},
    {v:accuracy+'%',l:'ACCURACY',c:'c-green',delta:'AI confidence'},
    {v:clusters.length,l:'CAMPAIGNS',c:'c-purple',delta:'Coordinated attacks'},
    {v:total-fake-suspect,l:'AUTHENTIC',c:'c-cyan',delta:'Verified genuine'},
  ].map(({v,l,c,delta})=>`<div class="metric-card ${c}">
    <div class="metric-val" style="color:${c.includes('red')?'var(--red)':c.includes('green')?'var(--green)':c.includes('orange')?'var(--orange)':c.includes('purple')?'var(--purple)':'var(--cyan)'}">${v}</div>
    <div class="metric-lbl">${l}</div>
    <div class="metric-delta" style="color:var(--muted)">${delta}</div>
  </div>`).join('');

  // Distribution chart
  const buckets=[0,0,0,0,0]; // 0-20,20-40,40-60,60-80,80-100
  reviews.forEach(r=>{const s=fakeScore(r,reviews);buckets[Math.min(Math.floor(s/20),4)]++;});
  const maxB=Math.max(...buckets,1);
  const bColors=['var(--green)','var(--green)','var(--orange)','var(--red)','var(--red)'];
  document.getElementById('dist-chart').innerHTML=buckets.map((b,i)=>`
    <div class="bar-col">
      <div class="bar-fill" style="height:${(b/maxB)*64}px;background:${bColors[i]};width:100%"></div>
      <div class="bar-lbl">${i*20}-${(i+1)*20}</div>
    </div>`).join('');

  // Heatmap
  document.getElementById('heatmap').innerHTML=Array.from({length:24},(_,i)=>{
    const intensity=Math.random();
    const color=intensity>0.7?'var(--red)':intensity>0.4?'var(--orange)':'var(--border2)';
    return `<div class="hm-cell" style="background:${color};opacity:${0.3+intensity*.7}" title="Hour ${i}:00 — ${Math.floor(intensity*10)} events"></div>`;
  }).join('');

  // IP origin
  const ipCounts={};
  reviews.forEach(r=>{const geo=IP_GEO[r.ip];if(geo){ipCounts[geo.country]=(ipCounts[geo.country]||0)+1;}});
  const sorted=Object.entries(ipCounts).sort((a,b)=>b[1]-a[1]);
  const maxC=Math.max(...sorted.map(([,v])=>v),1);
  document.getElementById('ip-origin-chart').innerHTML=sorted.map(([country,count])=>{
    const pct=Math.round(count/total*100);
    const isHigh=sorted.findIndex(([c])=>c===country)<2;
    return `<div style="display:flex;align-items:center;gap:10px;margin-bottom:7px;">
      <div style="min-width:90px;font-size:11px;color:var(--text)">${country}</div>
      <div style="flex:1;height:14px;background:var(--border);border-radius:3px;overflow:hidden">
        <div style="height:100%;width:${count/maxC*100}%;background:${isHigh?'var(--red)':'var(--cyan)'};border-radius:3px"></div>
      </div>
      <div style="min-width:45px;text-align:right;font-size:10px;color:${isHigh?'var(--red)':'var(--muted)'}">
        ${count} (${pct}%)
      </div>
    </div>`;}).join('');

  // Campaign summary
  document.getElementById('campaign-summary').innerHTML=clusters.length?clusters.map((c,i)=>{
    const ips=new Set(c.map(idx=>reviews[idx].ip));
    const texts=c.map(idx=>reviews[idx]);
    return `<div style="background:rgba(255,45,85,.06);border:1px solid rgba(255,45,85,.2);border-radius:6px;padding:10px 12px;margin-bottom:8px;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
        <span style="font-family:'Orbitron',monospace;font-size:10px;color:var(--red)">CAMPAIGN #${i+1}</span>
        <span style="font-size:9px;color:var(--muted)">${texts.length} reviews · ${ips.size} IPs</span>
        <button onclick="blockCampaign([${c.map(idx=>'"'+reviews[idx].ip+'"').join(',')}])" class="tt-btn danger" style="margin-left:auto;padding:2px 8px">BLOCK CAMPAIGN</button>
      </div>
      <div style="font-size:10px;color:var(--text)">"${texts[0].text.slice(0,80)}..."</div>
      <div style="font-size:9px;color:var(--muted);margin-top:4px">Similarity: ${(similarity(texts[0].text,texts[1]?.text||texts[0].text)*100).toFixed(0)}% · IPs: ${[...ips].join(', ')}</div>
    </div>`;}).join(''):`<div style="font-size:11px;color:var(--muted);text-align:center;padding:20px">No campaigns detected</div>`;
}

function blockCampaign(ips){
  showModal('🚨 BLOCK CAMPAIGN',`Block all IPs associated with this fake review campaign?<br><b style="color:var(--cyan)">${ips.length} IPs</b> will be blocked.`,()=>{
    ips.forEach(ip=>blockIP(ip,'Campaign block',true));
    toast(`🚫 Campaign blocked: ${ips.length} IPs`,'error',4000);
  });
}

// ===================== AI ANALYZE =====================
function sendToAnalyze(id){
  const r=reviews.find(x=>x.id===id);
  if(!r)return;
  document.getElementById('analyze-text').value=r.text;
  document.getElementById('analyze-ip').value=r.ip||'';
  document.getElementById('analyze-user').value=r.author||'';
  document.getElementById('analyze-rating').value=r.rating||5;
  showPanel('analyze');
}

const LOADING_STAGES=['TOKENIZING REVIEW TEXT...','COMPUTING LEVENSHTEIN DISTANCE...','RUNNING PHYLOGENETIC CLUSTERING...','CHECKING IP REPUTATION...','ANALYZING BEHAVIORAL PATTERNS...','GENERATING THREAT ASSESSMENT...'];

async function runDeepAnalysis(){
  const text=document.getElementById('analyze-text').value.trim();
  const ip=document.getElementById('analyze-ip').value.trim()||'Unknown';
  const user=document.getElementById('analyze-user').value.trim()||'Anonymous';
  const rating=document.getElementById('analyze-rating').value||5;
  if(!text){toast('Enter review text to analyze','error');return;}

  const btn=document.getElementById('analyze-btn');
  btn.disabled=true;
  document.getElementById('analyze-loading').style.display='block';
  document.getElementById('analyze-result').style.display='none';

  // Cycle loading stages
  let stageIdx=0;
  const stageInterval=setInterval(()=>{
    document.getElementById('loading-stage').textContent=LOADING_STAGES[stageIdx%LOADING_STAGES.length];
    stageIdx++;
  },700);

  // Local scoring
  const tempReview={id:99999,text,author:user,rating:parseInt(rating),ip,date:new Date().toISOString().split('T')[0]};
  const localScore=fakeScore(tempReview,[...reviews,tempReview]);
  const geo=IP_GEO[ip]||null;
  const topSim=reviews.map(r=>({r,s:similarity(text,r.text)})).sort((a,b)=>b.s-a.s).slice(0,3);

  try{
    const resp=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1200,
        messages:[{role:'user',content:`You are a fake review detection AI. Analyze this review submission and return ONLY valid JSON (no markdown, no extra text).

Review: "${text}"
Reviewer: ${user}
IP Address: ${ip}
Star Rating: ${rating}/5
Local similarity score: ${localScore}/100

Return this exact JSON structure:
{
  "fakeScore": <0-100>,
  "verdict": "<Authentic|Suspicious|Likely Fake|Definite Fake>",
  "confidence": <0-100>,
  "signals": [<4-6 short signal strings>],
  "ipRisk": "<Low|Medium|High|Critical>",
  "attackType": "<None|Template Bot|Review Farm|Competitor Attack|Astroturfing>",
  "linguisticDNA": "<2-3 word description of writing style>",
  "recommendation": "<Block|Flag|Review|Approve>",
  "reasoning": "<3-4 sentence analysis>"
}`}]
      })
    });
    const data=await resp.json();
    const raw=(data.content||[]).map(b=>b.text||'').join('');
    const result=JSON.parse(raw.replace(/```json|```/g,'').trim());
    clearInterval(stageInterval);
    showAnalysisResult(result,ip,geo,topSim,text);
    addTimelineEvent(`AI analysis: ${result.verdict} (${result.fakeScore}/100)`,ip,result.fakeScore>60?'danger':result.fakeScore>35?'warning':'success');
    if(result.recommendation==='Block')toast(`⚠ AI recommends blocking IP: ${ip}`,'error',5000);
  }catch(e){
    clearInterval(stageInterval);
    showAnalysisResult({fakeScore:localScore,verdict:'Analysis Error',confidence:60,signals:['AI unavailable — using local scoring'],ipRisk:'Unknown',attackType:'Unknown',linguisticDNA:'Unknown',recommendation:'Review',reasoning:'Could not reach AI API. Local phylogenetic score used.'},ip,geo,topSim,text);
  }
  document.getElementById('analyze-loading').style.display='none';
  btn.disabled=false;
}

