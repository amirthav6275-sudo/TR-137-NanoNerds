        <div class="dna-title">LINGUISTIC DNA FINGERPRINT</div>
        <div class="dna-bar">${text.split(/\s+/).map(w=>{
          const h=w.split('').reduce((a,c)=>a+c.charCodeAt(0),0)%360;
          return `<div class="dna-chunk" style="background:hsl(${h},70%,35%);flex:${Math.max(1,w.length*.4)}">${w[0]||'?'}</div>`;
        }).join('')}</div>
        <div style="font-size:9px;color:var(--muted)">Each segment = one word token. Color = lexical hash. Similar patterns across reviews indicate template origin.</div>
      </div>
      ${geo?`<div class="dna-section">
        <div class="dna-title">IP INTELLIGENCE: ${ip}</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:10px;color:var(--text)">
          <div>📍 ${geo.city}, ${geo.country}</div>
          <div>🏢 ${geo.isp}</div>
          <div>🔌 ${geo.type}</div>
          <div style="color:${geo.risk>70?'var(--red)':'var(--green)'};font-weight:700">⚠ Risk: ${geo.risk}%</div>
        </div>
      </div>`:''}
      ${topSim.filter(x=>x.s>0.4).length?`<div class="dna-section">
        <div class="dna-title">PHYLOGENETIC MATCHES (TOP SIMILAR REVIEWS)</div>
        ${topSim.filter(x=>x.s>0.4).map(({r:sr,s})=>`
          <div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--border);font-size:10px">
            <span style="color:var(--muted)">#${sr.id}</span>
            <span style="flex:1;color:var(--text)">${sr.text.slice(0,60)}...</span>
            <span style="color:${s>0.7?'var(--red)':'var(--orange)'};font-weight:700;font-family:'Orbitron',monospace">${(s*100).toFixed(0)}%</span>
          </div>`).join('')}
      </div>`:''}
      <div class="result-section-label" style="font-size:9px;color:var(--muted);letter-spacing:.15em;margin-bottom:6px;margin-top:12px">AI REASONING</div>
      <div class="reasoning-text">${r.reasoning||''}</div>
    </div>
  </div>`;
  document.getElementById('analyze-result').innerHTML=html;
  document.getElementById('analyze-result').style.display='block';
}

