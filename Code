    ipMap[r.ip].count++;
    ipMap[r.ip].reviews.push(r.id);
    if(fakeScore(r,reviews)>60)ipMap[r.ip].fakeCount++;
  });
  const ips=Object.values(ipMap).sort((a,b)=>b.fakeCount-a.fakeCount);

  document.getElementById('ip-grid').innerHTML=ips.map(({ip,count,fakeCount})=>{
    const geo=IP_GEO[ip]||{country:'Unknown',city:'Unknown',risk:50,isp:'Unknown',type:'Unknown'};
    const isBlocked=blockedIPs.has(ip);
    const risk=geo.risk;
    const riskColor=risk>70?'var(--red)':risk>40?'var(--orange)':'var(--green)';
    const badgeClass=isBlocked?'blocked':risk>70?'suspicious':'clean';
    return `<div class="ip-card${isBlocked?' blocked':''}">
      <div class="ip-card-header">
        <span class="ip-addr" style="color:${isBlocked?'var(--muted)':'var(--cyan)'}">${ip}</span>
