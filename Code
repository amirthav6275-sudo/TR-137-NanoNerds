let attackCounter=0;
function simulateAttack(){
  attackCounter++;
  const templates=[
    "Outstanding product! Absolutely love it. Best thing I bought this year!",
    "Outstanding product! Absolutely love this. Best purchase of the year!",
    "Outstanding! Absolutely love this product. Best buy of this year!",
  ];
  const attackIP=`185.220.${101+Math.floor(Math.random()*5)}.${Math.floor(Math.random()*255)}`;
  IP_GEO[attackIP]={country:'Russia',city:'Moscow',risk:95,isp:'TorGuard VPN',type:'VPN/Proxy'};

  templates.forEach((text,i)=>{
    setTimeout(()=>{
      const id=reviews.length+1;
      reviews.push({id,text,author:`bot_${attackCounter}_${i}`,date:new Date().toISOString().split('T')[0],rating:5,ip:attackIP,blocked:false});
      addTimelineEvent(`⚡ New review submitted (likely bot)`,attackIP,'danger');
      updateStats();renderAll();
      if(i===templates.length-1){
        setTimeout(()=>{
          toast(`🚨 Attack detected! ${templates.length} coordinated reviews from ${attackIP}`,'error',6000);
          addTimelineEvent(`🚨 CAMPAIGN DETECTED: ${templates.length} fake reviews auto-blocked`,attackIP,'danger');
          templates.forEach((_,j)=>{
            const r=reviews.find(x=>x.text===templates[j]&&x.ip===attackIP);
            if(r)r.blocked=true;
          });
          blockIP(attackIP,'Auto-blocked: Bot attack detected',true);
          updateStats();renderAll();
        },500);
      }
    },i*600);
  });
  toast(`⚡ Simulating bot attack from ${attackIP}...`,'info',3000);
}

function addReviewUI(){
