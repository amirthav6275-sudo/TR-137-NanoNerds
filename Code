// ===================== UTILS =====================
function levenshtein(a,b){
  const m=a.length,n=b.length;
  const dp=Array.from({length:m+1},(_,i)=>Array.from({length:n+1},(_,j)=>i===0?j:j===0?i:0));
  for(let i=1;i<=m;i++) for(let j=1;j<=n;j++) dp[i][j]=a[i-1]===b[j-1]?dp[i-1][j-1]:1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);
  return dp[m][n];
}
function similarity(a,b){const d=levenshtein(a.toLowerCase(),b.toLowerCase());return 1-d/Math.max(a.length,b.length);}

function fakeScore(r,all){
  let s=0;
  const sims=all.filter(x=>x.id!==r.id).map(x=>similarity(r.text,x.text));
  const max=Math.max(...sims,0);
  const high=sims.filter(x=>x>0.55).length;
  if(max>0.75)s+=45;else if(max>0.55)s+=28;
  if(high>2)s+=18;
  if(r.rating===5||r.rating===1)s+=8;
  if(r.text.split(' ').length<12)s+=9;
  const geo=IP_GEO[r.ip];
  if(geo){if(geo.risk>80)s+=15;else if(geo.risk>50)s+=8;}
  if(blockedIPs.has(r.ip))s+=20;
  return Math.min(s,100);
}

function scoreColor(s){return s>60?'var(--red)':s>35?'var(--orange)':'var(--green)';}
function scoreLabel(s){return s>60?'FAKE':s>35?'SUSPECT':'AUTHENTIC';}
function scoreClass(s){return s>60?'fake':s>35?'suspect':'clean';}

// ===================== AUTO-SHIELD ENGINE =====================
const AUTO_BLOCK_THRESHOLD = 60;
let autoShieldEnabled = true;
let autoBlockedCount = 0;

function autoShieldScan(showToasts=true){
  if(!autoShieldEnabled) return;
  let newlyBlocked = 0;
  reviews.forEach(r => {
    if(r.blocked) return; // already handled
    const sc = fakeScore(r, reviews);
    if(sc > AUTO_BLOCK_THRESHOLD){
      r.blocked = true;
      newlyBlocked++;
      autoBlockedCount++;
      // Block the IP silently (no modal, no confirmation)
      if(!blockedIPs.has(r.ip)){
        blockedIPs.add(r.ip);
        // Block all reviews from same IP
        reviews.forEach(x => { if(x.ip === r.ip) x.blocked = true; });
        const entry = {ip: r.ip, reason: `Auto-Shield: Fake score ${sc}/100`, time: timeNow()};
        blockLog.unshift(entry);
        addTimelineEvent(`🛡 AUTO-SHIELD blocked IP — fake score ${sc}`, r.ip, 'danger');
        if(showToasts) toast(`🛡 Auto-Shield: Blocked IP ${r.ip} (score: ${sc})`, 'error', 4000);
      } else {
        addTimelineEvent(`🛡 AUTO-SHIELD: Review #${r.id} suppressed (score ${sc})`, r.ip, 'danger');
      }
    }
  });
  if(newlyBlocked > 0){
    updateStats();
    renderAll();
  }
  return newlyBlocked;
}

function toggleAutoShield(){
  autoShieldEnabled = !autoShieldEnabled;
  const el = document.getElementById('autoshield-status');
  const btn = document.getElementById('autoshield-toggle-btn');
  if(autoShieldEnabled){
    el.style.color = 'var(--orange)';
    el.innerHTML = '<div class="status-dot" style="background:var(--orange);box-shadow:0 0 8px rgba(255,149,0,.6);animation:blink 2s infinite"></div>AUTO-SHIELD: ON';
    if(btn) { btn.textContent = '🛡 AUTO-SHIELD ON'; btn.style.color='var(--orange)'; btn.style.borderColor='rgba(255,149,0,.4)'; }
    toast('🛡 Auto-Shield ENABLED — fake reviews will be blocked automatically', 'success', 4000);
    autoShieldScan();
  } else {
    el.style.color = 'var(--muted)';
    el.innerHTML = '<div class="status-dot" style="background:var(--muted);animation:none"></div>AUTO-SHIELD: OFF';
    if(btn) { btn.textContent = '🛡 AUTO-SHIELD OFF'; btn.style.color='var(--muted)'; btn.style.borderColor='var(--border2)'; }
    toast('⚠ Auto-Shield DISABLED — manual review required', 'info', 4000);
  }
}

// Intercept reviews array push to auto-scan new entries
const _origPush = Array.prototype.push;
reviews.push = function(...args){
  const result = _origPush.apply(this, args);
  // Small delay to allow fakeScore to evaluate with full review set
  setTimeout(() => autoShieldScan(true), 100);
  return result;
};

