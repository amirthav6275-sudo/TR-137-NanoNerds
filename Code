        <circle cx="45" cy="45" r="38" fill="none" stroke="${color}" stroke-width="8"
          stroke-dasharray="${dash} ${circumference}" stroke-dashoffset="${circumference*0.25}"
          stroke-linecap="round" transform="rotate(-90 45 45)" style="filter:drop-shadow(0 0 6px ${color})"/>
