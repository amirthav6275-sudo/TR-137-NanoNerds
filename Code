<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>PhyloShield — Fake Review Detection Platform</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet"/>

<style>
/* ====== BASIC RESET ====== */
*{box-sizing:border-box;margin:0;padding:0;}
body{
  background:#030508;
  color:#d1e8ff;
  font-family:'Rajdhani',sans-serif;
}

/* ====== SIMPLE LAYOUT ====== */
#app{
  padding:20px;
}

/* ====== BUTTON ====== */
button{
  padding:8px 12px;
  background:#0a3d6b;
  color:#00f5ff;
  border:1px solid #00f5ff;
  border-radius:6px;
  cursor:pointer;
}

/* ====== CARD ====== */
.card{
  background:#0b1120;
  padding:12px;
  border-radius:8px;
  margin-bottom:10px;
}

/* ====== TEXTAREA ====== */
textarea{
  width:100%;
  padding:10px;
  border-radius:6px;
  background:#0e1628;
  color:white;
  border:1px solid #1e2f4a;
}
</style>
</head>

<body>

<div id="app">
  <h2>PhyloShield Demo</h2>

  <textarea id="reviewInput" rows="4" placeholder="Enter review..."></textarea>
  <br><br>
  <button onclick="analyze()">Analyze Review</button>

  <div id="result"></div>
</div>

<script>
/* ===== SAMPLE DATA ===== */
const SAMPLE_REVIEWS = [
  "Amazing product! Best purchase ever!",
  "Amazing product! Best purchase I made!",
  "Terrible quality, broke in one day",
  "Excellent item. Very satisfied."
];

/* ===== LEVENSHTEIN DISTANCE ===== */
function levenshtein(a,b){
  const m=a.length,n=b.length;
  const dp=Array.from({length:m+1},()=>Array(n+1).fill(0));

  for(let i=0;i<=m;i++) dp[i][0]=i;
  for(let j=0;j<=n;j++) dp[0][j]=j;

  for(let i=1;i<=m;i++){
    for(let j=1;j<=n;j++){
      dp[i][j]=a[i-1]===b[j-1]
        ? dp[i-1][j-1]
        : 1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);
    }
  }
  return dp[m][n];
}

/* ===== SIMILARITY ===== */
function similarity(a,b){
  const dist = levenshtein(a,b);
  return 1 - dist / Math.max(a.length,b.length);
}

/* ===== FAKE SCORE ===== */
function fakeScore(text){
  let score = 0;

  const sims = SAMPLE_REVIEWS.map(r => similarity(text,r));
  const maxSim = Math.max(...sims);

  if(maxSim > 0.75) score += 50;
  if(text.split(" ").length < 10) score += 20;

  return Math.min(score,100);
}

/* ===== ANALYZE FUNCTION ===== */
function analyze(){
  const input = document.getElementById("reviewInput").value;
  const score = fakeScore(input);

  let verdict = "AUTHENTIC";
  if(score > 60) verdict = "FAKE";
  else if(score > 35) verdict = "SUSPECT";

  document.getElementById("result").innerHTML = `
    <div class="card">
      <h3>Result</h3>
      <p><b>Score:</b> ${score}</p>
      <p><b>Verdict:</b> ${verdict}</p>
    </div>
  `;
}
</script>

</body>
</html>
